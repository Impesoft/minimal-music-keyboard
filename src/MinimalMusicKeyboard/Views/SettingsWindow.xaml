<Window
    x:Class="MinimalMusicKeyboard.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Minimal Music Keyboard — Settings">

    <Grid Padding="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,24"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24">

                <!-- Active instrument indicator -->
                <TextBlock x:Name="ActiveInstrumentLabel"
                           Text="Active instrument: —"
                           FontSize="12"
                           Opacity="0.7"
                           Margin="0,0,0,4"/>

                <!-- Volume -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Volume" FontWeight="SemiBold"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <Slider x:Name="VolumeSlider"
                                Grid.Column="0"
                                Minimum="0"
                                Maximum="100"
                                Value="100"
                                TickFrequency="10"
                                TickPlacement="None"
                                ValueChanged="OnVolumeChanged"/>
                        <TextBlock x:Name="VolumeLabel"
                                   Grid.Column="1"
                                   Text="100%"
                                   Width="44"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </Grid>
                </StackPanel>

                <!-- MIDI Device -->
                <StackPanel Spacing="8">
                    <TextBlock Text="MIDI Input Device" FontWeight="SemiBold"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <ComboBox x:Name="MidiDeviceCombo"
                                  Grid.Column="0"
                                  HorizontalAlignment="Stretch"
                                  PlaceholderText="No MIDI devices found"/>
                        <Button x:Name="RefreshMidiButton"
                                Grid.Column="1"
                                Content="↻"
                                ToolTipService.ToolTip="Refresh device list"
                                Margin="8,0,0,0"
                                Click="OnRefreshMidiClicked"/>
                    </Grid>
                    <TextBlock x:Name="MidiStatusText"
                               FontSize="12"
                               Opacity="0.6"/>
                </StackPanel>

                <!-- Audio Output Device -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Audio Output Device" FontWeight="SemiBold"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <ComboBox x:Name="AudioDeviceCombo"
                                  Grid.Column="0"
                                  HorizontalAlignment="Stretch"
                                  PlaceholderText="System default"/>
                        <Button Grid.Column="1"
                                Content="↻"
                                ToolTipService.ToolTip="Refresh device list"
                                Margin="8,0,0,0"
                                Click="OnRefreshAudioDeviceClicked"/>
                    </Grid>
                    <TextBlock x:Name="AudioDeviceStatusText"
                               FontSize="12"
                               Opacity="0.6"/>
                </StackPanel>

                <!-- Instrument Slots -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Instrument Slots" FontWeight="SemiBold"/>
                    <TextBlock Text="For each slot: browse for an instrument file (.sf2 or .vst3), then click Map and press a button on your MIDI device to trigger it."
                                FontSize="12" Opacity="0.6" TextWrapping="Wrap"/>
                    <StackPanel x:Name="ButtonMappingsPanel" Padding="0" Spacing="0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,20,0,0">
            <Button x:Name="TestSoundButton"
                    Content="▶ Test Sound"
                    ToolTipService.ToolTip="Plays middle C (C4) for 2 seconds to test the selected SoundFont"
                    Click="OnTestSoundClicked"/>
            <Button x:Name="SaveButton"
                    Content="Save"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OnSaveClicked"/>
            <Button Content="Close"
                    Click="OnCloseClicked"/>
        </StackPanel>

    </Grid>
</Window>

