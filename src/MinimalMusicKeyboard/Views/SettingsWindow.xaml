<Window
    x:Class="MinimalMusicKeyboard.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Minimal Music Keyboard — Settings">

    <Grid Padding="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,24"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24">

                <!-- MIDI Device -->
                <StackPanel Spacing="8">
                    <TextBlock Text="MIDI Input Device" FontWeight="SemiBold"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <ComboBox x:Name="MidiDeviceCombo"
                                  Grid.Column="0"
                                  HorizontalAlignment="Stretch"
                                  PlaceholderText="No MIDI devices found"/>
                        <Button x:Name="RefreshMidiButton"
                                Grid.Column="1"
                                Content="↻"
                                ToolTipService.ToolTip="Refresh device list"
                                Margin="8,0,0,0"
                                Click="OnRefreshMidiClicked"/>
                    </Grid>
                    <TextBlock x:Name="MidiStatusText"
                               FontSize="12"
                               Opacity="0.6"/>
                </StackPanel>

                <!-- SoundFont -->
                <StackPanel Spacing="8">
                    <TextBlock Text="SoundFont File (.sf2)" FontWeight="SemiBold"/>
                    <TextBlock Text="All instruments below will use this SoundFont."
                               FontSize="12"
                               Opacity="0.6"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox x:Name="SoundFontPathBox"
                                 Grid.Column="0"
                                 IsReadOnly="True"
                                 PlaceholderText="No SoundFont selected — click Browse…"/>
                        <Button x:Name="BrowseButton"
                                Grid.Column="1"
                                Content="Browse…"
                                Margin="8,0,0,0"
                                Click="OnBrowseClicked"/>
                    </Grid>
                    <TextBlock x:Name="SoundFontStatusText"
                               FontSize="12"
                               Opacity="0.6"/>
                </StackPanel>

                <!-- Instruments -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Instruments" FontWeight="SemiBold"/>
                    <TextBlock Text="Switch instruments from your MIDI keyboard using Program Change messages."
                               FontSize="12"
                               Opacity="0.6"
                               TextWrapping="Wrap"/>
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <ListView x:Name="InstrumentList"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  MaxHeight="200">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   x:Name="InstrumentName"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   x:Name="InstrumentCategory"
                                                   FontSize="11"
                                                   Opacity="0.5"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0"/>
                                        <TextBlock Grid.Column="2"
                                                   x:Name="InstrumentProgram"
                                                   FontSize="11"
                                                   Opacity="0.5"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,20,0,0">
            <Button x:Name="SaveButton"
                    Content="Save"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OnSaveClicked"/>
            <Button Content="Close"
                    Click="OnCloseClicked"/>
        </StackPanel>

    </Grid>
</Window>

